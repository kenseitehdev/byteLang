+static char *bl_join_qualified_name(char *base, BLToken part) {
+    size_t base_len = strlen(base);
+    size_t part_len = part.length;
+    char *name = (char *)realloc(base, base_len + 1 + part_len + 1);
+    if (!name) {
+        perror("realloc");
+        exit(1);
+    }
+    name[base_len] = '.';
+    memcpy(name + base_len + 1, part.start, part_len);
+    name[base_len + 1 + part_len] = '\0';
+    return name;
+}
+
+static char *bl_parse_qualified_name(BLParser *parser, const char *message) {
+    BLToken part = parser->current;
+    if (!bl_expect(parser, TOK_IDENT, message)) return NULL;
+
+    char *name = bl_token_text(part);
+    while (bl_match(parser, TOK_DOT)) {
+        BLToken next = parser->current;
+        if (!bl_expect(parser, TOK_IDENT, "expected identifier after '.'")) {
+            free(name);
+            return NULL;
+        }
+        name = bl_join_qualified_name(name, next);
+    }
+    return name;
+}
